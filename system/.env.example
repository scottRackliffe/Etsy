# Etsy Open API v3 – from https://www.etsy.com/developers/register
ETSY_CLIENT_ID=your_keystring
ETSY_CLIENT_SECRET=your_shared_secret

# Must match the redirect URI registered in your Etsy app (use HTTPS in production)
# Example local: http://localhost:3000/api/auth/etsy/callback
ETSY_REDIRECT_URI=http://localhost:3000/api/auth/etsy/callback

# Optional: if Etsy requires "keystring:sharedsecret" in x-api-key, set this and leave ETSY_CLIENT_ID as-is for OAuth
# ETSY_API_KEY_HEADER=your_keystring:your_shared_secret
